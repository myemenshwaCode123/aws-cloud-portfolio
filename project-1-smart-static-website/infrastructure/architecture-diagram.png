<svg width="800" height="520" viewBox="0 0 800 520" xmlns="http://www.w3.org/2000/svg" font-family="'Segoe UI', Arial, sans-serif">

  <rect width="800" height="520" fill="#0d1117" rx="12"/>

  <text x="400" y="34" text-anchor="middle" font-size="18" font-weight="600" fill="#FF9900">Smart Static Website — AWS Architecture</text>
  <text x="400" y="56" text-anchor="middle" font-size="12" fill="#8b949e">S3  ·  CloudFront  ·  ACM  ·  CloudWatch  ·  Free Tier ✅</text>

  <rect x="20" y="76" width="760" height="428" rx="10" fill="none" stroke="#30363d" stroke-width="1.5" stroke-dasharray="8 4"/>
  <text x="42" y="94" font-size="11" fill="#6e7681">AWS Cloud  (us-east-1)</text>

  <g>
    <rect x="296" y="96" width="208" height="56" rx="8" fill="#21262d" stroke="#6e7681" stroke-width="1"/>
    <text x="400" y="118" text-anchor="middle" font-size="13" font-weight="600" fill="#e6edf3">Internet User</text>
    <text x="400" y="138" text-anchor="middle" font-size="11" fill="#8b949e">Web browser (HTTPS)</text>
  </g>

  <line x1="400" y1="152" x2="400" y2="196" stroke="#58a6ff" stroke-width="1.5" marker-end="url(#arr-blue)"/>
  <text x="412" y="176" font-size="11" fill="#58a6ff">HTTPS / port 443</text>

  <g>
    <rect x="220" y="198" width="360" height="72" rx="8" fill="#0d2243" stroke="#1f6feb" stroke-width="1.5"/>
    <text x="400" y="222" text-anchor="middle" font-size="14" font-weight="600" fill="#79c0ff">Amazon CloudFront</text>
    <text x="400" y="244" text-anchor="middle" font-size="11" fill="#58a6ff">CDN  ·  HTTPS enforced  ·  Origin Access Control</text>
  </g>

  <g>
    <rect x="610" y="212" width="152" height="44" rx="8" fill="#1d1135" stroke="#6e40c9" stroke-width="1.5"/>
    <text x="686" y="228" text-anchor="middle" font-size="12" font-weight="600" fill="#bc8cff">ACM</text>
    <text x="686" y="246" text-anchor="middle" font-size="10" fill="#9a6ed8">SSL/TLS Certificate</text>
  </g>

  <line x1="610" y1="234" x2="580" y2="234" stroke="#6e40c9" stroke-width="1.2" marker-end="url(#arr-purple)"/>

  <line x1="400" y1="270" x2="400" y2="342" stroke="#3fb950" stroke-width="1.5" marker-end="url(#arr-green)"/>
  <text x="412" y="307" font-size="11" fill="#3fb950">OAC (private)</text>

  <path d="M 580 252 L 596 252 L 596 378 L 610 378" fill="none" stroke="#6e7681" stroke-width="1" stroke-dasharray="5 3" marker-end="url(#arr-gray)"/>
  <text x="598" y="316" font-size="10" fill="#6e7681">metrics</text>

  <g>
    <rect x="220" y="344" width="360" height="72" rx="8" fill="#062e2e" stroke="#238636" stroke-width="1.5"/>
    <text x="400" y="368" text-anchor="middle" font-size="14" font-weight="600" fill="#56d364">Amazon S3</text>
    <text x="400" y="390" text-anchor="middle" font-size="11" fill="#3fb950">Private bucket  ·  Block all public access  ·  index.html + error.html</text>
  </g>

  <g>
    <rect x="610" y="354" width="152" height="72" rx="8" fill="#2d1b00" stroke="#e3b341" stroke-width="1.5"/>
    <text x="686" y="378" text-anchor="middle" font-size="12" font-weight="600" fill="#f0c040">CloudWatch</text>
    <text x="686" y="396" text-anchor="middle" font-size="10" fill="#c9a227">Dashboards</text>
    <text x="686" y="412" text-anchor="middle" font-size="10" fill="#c9a227">5xx Alarms · SNS</text>
  </g>

  <line x1="76" y1="462" x2="100" y2="462" stroke="#1f6feb" stroke-width="2"/>
  <text x="106" y="466" font-size="11" fill="#8b949e">Direct traffic flow</text>
  <line x1="210" y1="462" x2="234" y2="462" stroke="#6e7681" stroke-width="1.5" stroke-dasharray="4 3"/>
  <text x="240" y="466" font-size="11" fill="#8b949e">Metrics / config</text>
  <rect x="366" y="455" width="12" height="12" rx="2" fill="#0d2243" stroke="#1f6feb" stroke-width="1.5"/>
  <text x="384" y="466" font-size="11" fill="#8b949e">Service</text>

  <defs>
    <marker id="arr-blue" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#58a6ff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
    <marker id="arr-green" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#3fb950" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
    <marker id="arr-purple" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#6e40c9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
    <marker id="arr-gray" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#6e7681" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
  </defs>

</svg>
